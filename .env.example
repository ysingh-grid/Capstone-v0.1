# ── Geometry Agent Harness — Environment Configuration ──────────────────────

# Anthropic API key for Claude Sonnet (Planner/Coder/Refiner) and
# Claude Opus (Judge/Verifier). Required for all LLM agent calls.
ANTHROPIC_API_KEY=

# Temporal server address (default: local dev server started via
# `temporal server start-dev`). For production use a Temporal Cloud
# namespace endpoint.
TEMPORAL_HOST=localhost:7233

# Temporal namespace (default for local dev server)
TEMPORAL_NAMESPACE=default

# Local filesystem path for the artifact store (STEP, STL, renders,
# trace JSON). Created automatically at runtime if it does not exist.
ARTIFACT_STORE_PATH=./artifacts

# Maximum depth for the inner execution-error repair loop (CADSmith default: 3)
MAX_ERROR_RETRIES=3

# Maximum depth for the outer geometric-refinement loop (CADSmith default: 5)
MAX_REFINEMENT_ITERATIONS=5

# CadQuery subprocess execution timeout in seconds
EXECUTOR_TIMEOUT_SECONDS=60

# Global hard cap on total workflow wall-clock runtime in seconds.
# Covers planning, code generation, CadQuery execution, inner code repair
# loop, verification, outer refinement loop, and handoff. When exceeded the
# workflow returns terminal FAILED with a user-facing timeout message.
MAX_TOTAL_RUNTIME_SECONDS=600

# Enable or disable VTK three-view visual verification (true/false)
USE_VISION=true
